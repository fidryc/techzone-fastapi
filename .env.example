# ============================================
# Режим работы приложения
# ============================================
# DEV - разработка, TEST - тестирование, PROD - продакшен
MODE=PROD
LOG_LEVEL=DEBUG

# ============================================
# База данных (основная - для режима DEV)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techzone
DB_USER=postgres
DB_PASS=postgres

# ============================================
# База данных (тестовая - для режима TEST)
# ============================================
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=test_techzone
TEST_DB_USER=postgres
TEST_DB_PASS=postgres

# ============================================
# База данных (продакшен - для режима PROD)
# ============================================
PROD_DB_HOST=db
PROD_DB_PORT=5432
PROD_DB_NAME=techzone
PROD_DB_USER=postgres
PROD_DB_PASS=postgres

# ============================================
# JWT аутентификация (RSA ключи)
# ============================================
# Пути к ключам (относительно корня проекта)
PRIVATE_SECRET_PATH=keys/jwt-private.pem
PUBLIC_SECRET_PATH=keys/jwt-public.pem

# Алгоритм шифрования
ALGORITM=RS256

# Время жизни токенов
EXP_SEC=10                       # Access токен (секунды) - для разработки
EXP_REFRESH_DAYS=30              # Refresh токен (дни)

# Названия cookie
JWT_ACCESS_COOKIE_NAME=access_token
JWT_REFRESH_COOKIE_NAME=refresh_token
JWT_VERIFY_REGISTRATION_COOKIE_NAME=verify_register_token

# ============================================
# Email настройки (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here    # Используйте пароль приложения Gmail

# Email для уведомлений курьерской службы
COURIER_EMAIL=courier@example.com

# ============================================
# Redis (для кэширования и Celery)
# ============================================
# Для режима DEV
REDIS_HOST_=localhost
REDIS_PORT_=6379

# Для режима PROD
PROD_REDIS_HOST=redis
PROD_REDIS_PORT=6379

# Для режима TEST
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379

# ============================================
# RabbitMQ (для очередей задач)
# ============================================
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Для режима DEV
RABBITMQ_HOST=localhost

# Для режима PROD
RABBITMQ_HOST_PROD=rabbitmq

RABBITMQ_PORT=5672

# Название очереди для уведомлений о формировании заказа
RBMQ_QUEUE_SEND_MAIL_ORDER_FORMATION=send_mail_order_formation

# ============================================
# Верификация регистрации
# ============================================
# Время жизни кода подтверждения (секунды)
VER_CODE_EXP_SEC=300

# Максимальное количество попыток ввода кода
MAX_TRIES_EMAIL_CODE=3

# Лимит на получение кода с одного IP (секунды)
LIMIT_SECONDS_GET_CODE=30

# ============================================
# Elasticsearch (для полнотекстового поиска)
# ============================================
# Для режимов DEV и TEST
ELASTIC_HOST=localhost

# Для режима PROD
ELASTIC_HOST_PROD=elasticsearch

ELASTIC_PORT=9200

# Название индекса для товаров
INDEX_PRODUCTS=index_products

# ============================================
# Административная панель
# ============================================
ADMIN_URL_STARTSWITH=admin